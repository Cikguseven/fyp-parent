#!/bin/bash
#PBS -P CFP01-CF-060
#PBS -N downstream_lm_eval
#PBS -q auto
#PBS -l select=1:ngpus=1
#PBS -l walltime=96:00:00
#PBS -j oe

export APPTAINERENV_TORCHMETRICS_SKIP_IMAGE_DIST_TESTS=1

cd $PBS_O_WORKDIR

module load singularity
IMAGE="/app1/common/singularity-img/hopper/cuda/cuda_12.1.0-cudnn8-devel-u20.04.sif"

singularity exec -e $IMAGE bash << 'EOF' \
    > "/scratch/Projects/CFP-01/CFP01-CF-060/kieron/olmo/$PBS_JOBNAME.$PBS_JOBID.stdout.log" \
    2> "/scratch/Projects/CFP-01/CFP01-CF-060/kieron/olmo/$PBS_JOBNAME.$PBS_JOBID.stderr.log"

source /hpctmp/e0968891/virtualenvs/olmo/bin/activate

export PYTHONNOUSERSITE=1
export MY_LIBS="/scratch/Projects/CFP-01/CFP01-CF-060/kieron/job_libs"
export PYTHONPATH="/scratch/Projects/CFP-01/CFP01-CF-060/code/OLMo:$MY_LIBS:${PYTHONPATH:-}"

echo "Starting at $(date)"

mkdir -p /scratch/Projects/CFP-01/CFP01-CF-060/kieron/blt/downstream/lmeval_results
cd /scratch/Projects/CFP-01/CFP01-CF-060/kieron/blt/downstream

python pipeline_lm_eval.py \
    --model_path /data/models/olmo-local-myte \
    --tokenizer_name myte \
    --output_dir /scratch/Projects/CFP-01/CFP01-CF-060/kieron/blt/downstream/lmeval_results/myte

EOF